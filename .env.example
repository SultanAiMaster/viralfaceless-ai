# ViralFaceless AI - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=production

# Redis Configuration (for BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB Configuration (for analytics & content storage)
MONGODB_URI=mongodb://localhost:27017/viralfaceless

# OpenAI API (for script writing & metadata)
OPENAI_API_KEY=sk-...

# ElevenLabs API (for AI voiceover)
ELEVENLABS_API_KEY=...

# MuleRouter API (for AI video generation)
MULEROUTER_API_KEY=...

# YouTube API Credentials
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/callback
YOUTUBE_REFRESH_TOKEN=...

# Channel Keys (10 channels)
# Each channel needs separate OAuth tokens
CHANNEL_1_REFRESH_TOKEN=...
CHANNEL_2_REFRESH_TOKEN=...
CHANNEL_3_REFRESH_TOKEN=...
CHANNEL_4_REFRESH_TOKEN=...
CHANNEL_5_REFRESH_TOKEN=...
CHANNEL_6_REFRESH_TOKEN=...
CHANNEL_7_REFRESH_TOKEN=...
CHANNEL_8_REFRESH_TOKEN=...
CHANNEL_9_REFRESH_TOKEN=...
CHANNEL_10_REFRESH_TOKEN=...

# Logging
LOG_LEVEL=info

# Content Paths
CONTENT_DIR=./content
TEMP_DIR=./temp
